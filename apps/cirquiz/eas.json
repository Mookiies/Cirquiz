{
  "cli": {
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "environment": "development",
      "env": { "APP_ENV": "development" }
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview",
      "env": { "APP_ENV": "staging" }
    },
    "production": {
      "distribution": "store",
      "environment": "production",
      "autoIncrement": true,
      "env": { "APP_ENV": "production" }
    }
  }
}
